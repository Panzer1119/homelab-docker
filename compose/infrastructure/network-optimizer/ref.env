# Host IP/name for path analysis and CORS (required for client speed tests)
# And For URL construction and host enforcement redirect
HOST_IP="op://Docker/Network-Optimizer/Host/IP"
#HOST_NAME="network-optimizer"
HOST_NAME="op://Docker/Network-Optimizer/Host/Name"
# Reverse proxy hostname (e.g., optimizer.example.com) - overrides HOST_NAME for API URLs
# And For result reporting URL
REVERSE_PROXIED_HOST_NAME="op://Docker/Network-Optimizer/Host/Reverse-Proxied-Name"
# OpenSpeedTest configuration (for UI display and CORS)
OPENSPEEDTEST_PORT="op://Docker/Network-Optimizer/OpenSpeedTest/Port"
OPENSPEEDTEST_HOST="op://Docker/Network-Optimizer/OpenSpeedTest/Host"
OPENSPEEDTEST_HTTPS="op://Docker/Network-Optimizer/OpenSpeedTest/HTTPS"
OPENSPEEDTEST_HTTPS_PORT="op://Docker/Network-Optimizer/OpenSpeedTest/HTTPS-Port"
