# Bind to localhost only (for reverse proxy) or all interfaces (direct access)
BIND_LOCALHOST_ONLY="false"
APP_PASSWORD="op://Docker/Network-Optimizer/App-Password"
#DEMO_MODE_MAPPINGS=
# iperf3 server mode - enable to accept client-initiated speed tests on port 5201
Iperf3Server__Enabled="true"
# Logging (Trace, Debug, Information, Warning, Error, Critical)
Logging__LogLevel__Default="Information"
Logging__LogLevel__NetworkOptimizer="Information"
# Point to existing InfluxDB if desired (optional)
INFLUXDB_URL="op://Docker/Network-Optimizer/InfluxDB/URL"
INFLUXDB_TOKEN="op://Docker/Network-Optimizer/InfluxDB/Token"
INFLUXDB_ORG="op://Docker/Network-Optimizer/InfluxDB/Organization"
INFLUXDB_BUCKET="op://Docker/Network-Optimizer/InfluxDB/Bucket"
